---
/**
 * TesterModal — Beta tester signup form in a modal.
 * Triggered by any element with [data-open-tester-modal].
 */
interface Props {
  apiUrl?: string;
}

const { apiUrl = 'https://games.sabino.cl/zoominchile/api/testers' } = Astro.props;
---

<div class="tm-overlay" id="testerModal">
  <div class="tm-modal">
    <button class="tm-close" aria-label="Close">&times;</button>

    <!-- Step 1: Choose platform -->
    <div class="tm-step" id="tmStepPlatform">
      <div class="tm-icon"><i class="ph ph-device-mobile"></i></div>
      <h3 class="tm-title" data-es="Probar la App" data-en="Try the App">Probar la App</h3>
      <p class="tm-desc" data-es="&iquest;En qu&eacute; plataforma quieres jugar?" data-en="Which platform do you want to play on?">&iquest;En qu&eacute; plataforma quieres jugar?</p>
      <div class="tm-platform-btns">
        <button class="tm-platform-btn" data-platform="android">
          <i class="ph ph-google-play-logo"></i>
          <span>Google Play</span>
        </button>
        <button class="tm-platform-btn tm-platform-apple" data-platform="ios">
          <i class="ph ph-apple-logo"></i>
          <div class="tm-store-label">
            <span>App Store</span>
            <small data-es="Pr&oacute;ximamente" data-en="Coming soon">Pr&oacute;ximamente</small>
          </div>
        </button>
      </div>
    </div>

    <!-- Step 2: Choose method (Android) -->
    <div class="tm-step" id="tmStepMethod" style="display:none;">
      <div class="tm-icon"><i class="ph ph-google-play-logo"></i></div>
      <h3 class="tm-title" data-es="Google Play" data-en="Google Play">Google Play</h3>
      <p class="tm-desc" data-es="Elige c&oacute;mo quieres acceder a la app" data-en="Choose how to access the app">Elige c&oacute;mo quieres acceder a la app</p>
      <div class="tm-platform-btns">
        <button class="tm-platform-btn" id="tmMethodAuto">
          <i class="ph ph-lightning"></i>
          <div class="tm-store-label">
            <span data-es="Unirme al grupo de testers" data-en="Join the testers group">Unirme al grupo de testers</span>
            <small data-es="Casi autom&aacute;tico" data-en="Almost automatic">Casi autom&aacute;tico</small>
          </div>
        </button>
        <button class="tm-platform-btn" id="tmMethodManual">
          <i class="ph ph-envelope-simple"></i>
          <div class="tm-store-label">
            <span data-es="Enviar mis datos" data-en="Send my info">Enviar mis datos</span>
            <small data-es="Proceso manual" data-en="Manual process">Proceso manual</small>
          </div>
        </button>
      </div>
      <button type="button" class="tm-back" id="tmBackMethod">
        <i class="ph ph-arrow-left"></i>
        <span data-es="Volver" data-en="Back">Volver</span>
      </button>
    </div>

    <!-- Step 3a: Form (Android — manual) -->
    <div class="tm-step" id="tmStepForm" style="display:none;">
      <div class="tm-icon"><i class="ph ph-google-play-logo"></i></div>
      <h3 class="tm-title" data-es="Google Play" data-en="Google Play">Google Play</h3>
      <p class="tm-desc" data-es="Ingresa el Gmail con el que tienes configurada tu Play Store." data-en="Enter the Gmail linked to your Play Store.">Ingresa el Gmail con el que tienes configurada tu Play Store.</p>
      <form class="tm-form" id="testerForm" data-api={apiUrl} novalidate>
        <input type="hidden" name="platform" value="android" />
        <input
          type="text"
          name="name"
          class="tm-input"
          data-placeholder-es="Nombre"
          data-placeholder-en="Name"
          placeholder="Nombre"
        />
        <input
          type="text"
          name="email"
          class="tm-input"
          data-placeholder-es="Gmail (tu cuenta de Play Store)"
          data-placeholder-en="Gmail (your Play Store account)"
          placeholder="Gmail (tu cuenta de Play Store)"
        />
        <div class="tm-validation" id="testerValidation" style="display:none;"
          data-name-es="Ingresa tu nombre"
          data-name-en="Enter your name"
          data-email-es="Ingresa un email v&aacute;lido"
          data-email-en="Enter a valid email"
        ></div>
        <button type="submit" class="tm-submit">
          <span data-es="Enviar" data-en="Submit">Enviar</span>
          <i class="ph ph-arrow-right"></i>
        </button>
        <button type="button" class="tm-back" id="tmBack">
          <i class="ph ph-arrow-left"></i>
          <span data-es="Volver" data-en="Back">Volver</span>
        </button>
      </form>
    </div>

    <!-- Step 2: Coming soon (iOS) -->
    <div class="tm-step" id="tmStepIos" style="display:none;">
      <div class="tm-icon tm-icon-apple"><i class="ph ph-apple-logo"></i></div>
      <h3 class="tm-title">App Store</h3>
      <p class="tm-desc" data-es="Estamos trabajando en la versi&oacute;n para iOS. D&eacute;janos tus datos y te avisaremos cuando est&eacute; lista." data-en="We're working on the iOS version. Leave your info and we'll notify you when it's ready.">Estamos trabajando en la versi&oacute;n para iOS. D&eacute;janos tus datos y te avisaremos cuando est&eacute; lista.</p>
      <form class="tm-form" id="testerFormIos" data-api={apiUrl} novalidate>
        <input type="hidden" name="platform" value="ios" />
        <input
          type="text"
          name="name"
          class="tm-input"
          data-placeholder-es="Nombre"
          data-placeholder-en="Name"
          placeholder="Nombre"
        />
        <input
          type="text"
          name="email"
          class="tm-input"
          data-placeholder-es="Email"
          data-placeholder-en="Email"
          placeholder="Email"
        />
        <div class="tm-validation" id="testerValidationIos" style="display:none;"
          data-name-es="Ingresa tu nombre"
          data-name-en="Enter your name"
          data-email-es="Ingresa un email v&aacute;lido"
          data-email-en="Enter a valid email"
        ></div>
        <button type="submit" class="tm-submit">
          <span data-es="Avisarme" data-en="Notify me">Avisarme</span>
          <i class="ph ph-bell"></i>
        </button>
        <button type="button" class="tm-back" id="tmBackIos">
          <i class="ph ph-arrow-left"></i>
          <span data-es="Volver" data-en="Back">Volver</span>
        </button>
      </form>
    </div>

    <!-- Success: Android — manual (admin adds tester) -->
    <div class="tm-step" id="testerSuccessManual" style="display:none;">
      <div class="tm-success-icon"><i class="ph ph-check-circle"></i></div>
      <p class="tm-desc" data-es="&iexcl;Recibimos tus datos! Te agregaremos como tester y te avisaremos por correo cuando puedas descargar la app." data-en="Got it! We'll add you as a tester and notify you by email when you can download the app.">&iexcl;Recibimos tus datos! Te agregaremos como tester y te avisaremos por correo cuando puedas descargar la app.</p>
    </div>

    <!-- Success: Android — guided stepper (self-service) -->
    <div class="tm-step" id="testerSuccess" style="display:none;">
      <h3 class="tm-title" data-es="Ya casi est&aacute;s" data-en="Almost there">Ya casi est&aacute;s</h3>
      <p class="tm-desc" data-es="Completa estos pasos para descargar la app" data-en="Complete these steps to download the app">Completa estos pasos para descargar la app</p>

      <div class="tm-stepper">
        <!-- Step 1: Join Google Group -->
        <div class="tm-stepper-item tm-stepper-active" data-stepper="0">
          <div class="tm-stepper-header">
            <div class="tm-stepper-num">1</div>
            <div class="tm-stepper-label" data-es="Unirse al grupo de Google" data-en="Join the Google Group">Unirse al grupo de Google</div>
          </div>
          <div class="tm-stepper-body">
            <p data-es="Abre el grupo y haz clic en &laquo;Unirse al grupo&raquo;. Elige cualquier opci&oacute;n de suscripci&oacute;n." data-en="Open the group and click &laquo;Join group&raquo;. Choose any subscription option.">Abre el grupo y haz clic en &laquo;Unirse al grupo&raquo;. Elige cualquier opci&oacute;n de suscripci&oacute;n.</p>
            <a href="https://groups.google.com/g/zoom-in-chile-testers/" target="_blank" rel="noopener" class="tm-stepper-link">
              <i class="ph ph-arrow-square-out"></i>
              <span data-es="Abrir Google Groups" data-en="Open Google Groups">Abrir Google Groups</span>
            </a>
            <button type="button" class="tm-stepper-confirm">
              <i class="ph ph-check"></i>
              <span data-es="Ya me un&iacute;" data-en="I joined">Ya me un&iacute;</span>
            </button>
          </div>
        </div>

        <!-- Step 2: Become a tester -->
        <div class="tm-stepper-item" data-stepper="1">
          <div class="tm-stepper-header">
            <div class="tm-stepper-num">2</div>
            <div class="tm-stepper-label" data-es="Ser tester" data-en="Become a tester">Ser tester</div>
          </div>
          <div class="tm-stepper-body">
            <p data-es="Abre la p&aacute;gina y haz clic en &laquo;Convertirse en tester&raquo;." data-en="Open the page and click &laquo;Become a tester&raquo;.">Abre la p&aacute;gina y haz clic en &laquo;Convertirse en tester&raquo;.</p>
            <a href="https://play.google.com/apps/testing/cl.depointless.zoominchile" target="_blank" rel="noopener" class="tm-stepper-link">
              <i class="ph ph-arrow-square-out"></i>
              <span data-es="Abrir Google Play" data-en="Open Google Play">Abrir Google Play</span>
            </a>
            <button type="button" class="tm-stepper-confirm">
              <i class="ph ph-check"></i>
              <span data-es="Ya soy tester" data-en="I'm a tester">Ya soy tester</span>
            </button>
          </div>
        </div>

        <!-- Step 3: Download -->
        <div class="tm-stepper-item" data-stepper="2">
          <div class="tm-stepper-header">
            <div class="tm-stepper-num">3</div>
            <div class="tm-stepper-label" data-es="Descargar la app" data-en="Download the app">Descargar la app</div>
          </div>
          <div class="tm-stepper-body">
            <p data-es="&iexcl;Listo! Ahora s&iacute; puedes descargar el juego." data-en="All set! Now you can download the game.">&iexcl;Listo! Ahora s&iacute; puedes descargar el juego.</p>
            <a href="https://play.google.com/store/apps/details?id=cl.depointless.zoominchile" target="_blank" rel="noopener" class="tm-submit" style="text-decoration:none;">
              <i class="ph ph-google-play-logo"></i>
              <span data-es="Descargar en Google Play" data-en="Download on Google Play">Descargar en Google Play</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Success: iOS -->
    <div class="tm-step" id="testerSuccessIos" style="display:none;">
      <div class="tm-success-icon"><i class="ph ph-check-circle"></i></div>
      <p class="tm-desc" data-es="&iexcl;Listo! Te avisaremos cuando est&eacute; disponible en App Store." data-en="Done! We'll notify you when it's available on the App Store.">&iexcl;Listo! Te avisaremos cuando est&eacute; disponible en App Store.</p>
    </div>

    <div class="tm-error" id="testerError" style="display:none;">
      <p data-es="Hubo un error. Int&eacute;ntalo de nuevo." data-en="Something went wrong. Try again.">Hubo un error. Int&eacute;ntalo de nuevo.</p>
    </div>
  </div>
</div>

<style is:inline>
  .tm-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }

  .tm-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .tm-modal {
    background: #FFFFFF;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    max-width: 420px;
    width: 100%;
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    transform: translateY(16px);
    transition: transform 0.25s;
  }

  .tm-overlay.open .tm-modal {
    transform: translateY(0);
  }

  .tm-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 32px;
    height: 32px;
    border: none;
    background: #F5F7FA;
    border-radius: 50%;
    font-size: 1.2rem;
    color: #6B7280;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .tm-close:hover { background: #E5E7EB; }

  .tm-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #E3F2FD;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .tm-icon .ph {
    font-size: 1.4rem;
    color: #1565C0;
  }

  .tm-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #1A1A1A;
    margin-bottom: 0.5rem;
  }

  .tm-desc {
    font-size: 0.9rem;
    color: #6B7280;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .tm-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tm-input {
    padding: 0.75rem 1rem;
    border: 1px solid #E5E7EB;
    border-radius: 10px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.9rem;
    color: #1A1A1A;
    background: #FFFFFF;
    outline: none;
    transition: border-color 0.2s;
  }

  .tm-input:focus {
    border-color: #1565C0;
    box-shadow: 0 0 0 3px rgba(21, 101, 192, 0.1);
  }

  .tm-input::placeholder { color: #9CA3AF; }

  .tm-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: #1565C0;
    color: white;
    border: none;
    border-radius: 10px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 0.25rem;
  }

  .tm-submit:hover { background: #1976D2; }
  .tm-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  .tm-success-icon {
    font-size: 2.5rem;
    color: #4CAF50;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .tm-error p {
    color: #E53935;
    font-size: 0.85rem;
    text-align: center;
  }

  .tm-validation {
    color: #E53935;
    font-size: 0.8rem;
    text-align: center;
  }

  .tm-input.invalid {
    border-color: #E53935;
  }

  .tm-platform-btns {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tm-platform-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    border: 1px solid #E5E7EB;
    background: #FFFFFF;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: #1A1A1A;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
    text-align: left;
  }

  .tm-platform-btn .ph { font-size: 1.4rem; color: #1565C0; }
  .tm-platform-btn:hover { border-color: #1565C0; background: #F0F7FF; }

  .tm-platform-apple {
    color: #9CA3AF;
  }
  .tm-platform-apple .ph { color: #9CA3AF; }
  .tm-platform-apple:hover { border-color: #E5E7EB; background: #FFFFFF; cursor: default; }

  .tm-store-label {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .tm-store-label small {
    font-size: 0.7rem;
    font-weight: 400;
  }

  .tm-icon-apple { background: #F5F7FA; }
  .tm-icon-apple .ph { color: #1A1A1A; }

  .tm-back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.5rem 1rem;
    background: none;
    border: none;
    color: #6B7280;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.8rem;
    cursor: pointer;
    transition: color 0.2s;
  }
  .tm-back:hover { color: #1A1A1A; }

  /* ── Stepper ── */
  .tm-stepper { display: flex; flex-direction: column; gap: 0; width: 100%; }

  .tm-stepper-item {
    position: relative;
    padding-left: 40px;
    padding-bottom: 1.25rem;
  }
  .tm-stepper-item:last-child { padding-bottom: 0; }

  /* Vertical connector line */
  .tm-stepper-item::before {
    content: '';
    position: absolute;
    left: 13px;
    top: 32px;
    bottom: -4px;
    width: 2px;
    background: #E5E7EB;
    transition: background 0.3s;
  }
  .tm-stepper-item:last-child::before { display: none; }
  .tm-stepper-item.tm-stepper-done::before { background: #4CAF50; }

  .tm-stepper-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    position: relative;
  }

  .tm-stepper-num {
    position: absolute;
    left: -40px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid #E5E7EB;
    background: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #9CA3AF;
    transition: all 0.3s;
    flex-shrink: 0;
    z-index: 1;
  }
  .tm-stepper-num .ph { font-size: 0.85rem; }

  .tm-stepper-active .tm-stepper-num {
    border-color: #1565C0;
    background: #1565C0;
    color: #FFFFFF;
  }
  .tm-stepper-done .tm-stepper-num {
    border-color: #4CAF50;
    background: #4CAF50;
    color: #FFFFFF;
  }

  .tm-stepper-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #9CA3AF;
    transition: color 0.3s;
  }
  .tm-stepper-active .tm-stepper-label { color: #1A1A1A; }
  .tm-stepper-done .tm-stepper-label { color: #4CAF50; }

  .tm-stepper-body {
    display: none;
    padding-top: 0.6rem;
    max-width: 100%;
  }
  .tm-stepper-active .tm-stepper-body { display: block; }

  .tm-stepper-body p {
    font-size: 0.8rem;
    color: #6B7280;
    line-height: 1.5;
    margin-bottom: 0.65rem;
  }

  .tm-stepper-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    box-sizing: border-box;
    padding: 0.65rem 1rem;
    border: 1px solid #E5E7EB;
    border-radius: 10px;
    background: #FFFFFF;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #1565C0;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
  }
  .tm-stepper-link:hover { border-color: #1565C0; background: #F0F7FF; }
  .tm-stepper-link .ph { font-size: 1rem; }

  .tm-stepper-confirm {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    width: 100%;
    box-sizing: border-box;
    margin-top: 0.5rem;
    padding: 0.55rem 1rem;
    border: none;
    border-radius: 10px;
    background: #4CAF50;
    color: #FFFFFF;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .tm-stepper-confirm:hover { background: #43A047; }
</style>

<script is:inline>
  (function() {
    const overlay = document.getElementById('testerModal');
    if (!overlay) return;

    const steps = {
      platform: document.getElementById('tmStepPlatform'),
      method: document.getElementById('tmStepMethod'),
      form: document.getElementById('tmStepForm'),
      ios: document.getElementById('tmStepIos'),
      success: document.getElementById('testerSuccess'),
      successManual: document.getElementById('testerSuccessManual'),
      successIos: document.getElementById('testerSuccessIos'),
    };
    const errorEl = document.getElementById('testerError');
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    function showStep(name) {
      Object.values(steps).forEach(s => { if (s) s.style.display = 'none'; });
      errorEl.style.display = 'none';
      if (steps[name]) steps[name].style.display = '';
    }

    // Open modal — always reset to platform step
    document.querySelectorAll('[data-open-tester-modal]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        showStep('platform');
        overlay.classList.add('open');
      });
    });

    // Close modal
    overlay.querySelector('.tm-close').addEventListener('click', () => overlay.classList.remove('open'));
    overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('open'); });

    // Platform selection
    overlay.querySelector('[data-platform="android"]').addEventListener('click', () => showStep('method'));
    overlay.querySelector('[data-platform="ios"]').addEventListener('click', () => showStep('ios'));

    // Method selection
    document.getElementById('tmMethodAuto').addEventListener('click', () => showStep('success'));
    document.getElementById('tmMethodManual').addEventListener('click', () => showStep('form'));

    // Back buttons
    document.getElementById('tmBackMethod').addEventListener('click', () => showStep('platform'));
    document.getElementById('tmBack').addEventListener('click', () => showStep('method'));
    document.getElementById('tmBackIos').addEventListener('click', () => showStep('platform'));

    // Generic form handler
    function setupForm(formId, validationId, successStep) {
      const form = document.getElementById(formId);
      const validationEl = document.getElementById(validationId);
      if (!form) return;

      function showValidation(key) {
        const lang = document.documentElement.lang || 'es';
        validationEl.textContent = validationEl.getAttribute('data-' + key + '-' + lang) || '';
        validationEl.style.display = 'block';
      }

      form.querySelectorAll('.tm-input').forEach(input => {
        input.addEventListener('input', () => { input.classList.remove('invalid'); validationEl.style.display = 'none'; });
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        validationEl.style.display = 'none';
        errorEl.style.display = 'none';
        const btn = form.querySelector('.tm-submit');

        const name = form.name.value.trim();
        const email = form.email.value.trim();
        const platform = form.platform.value;

        if (!name) { form.name.classList.add('invalid'); showValidation('name'); return; }
        if (!email || !emailRegex.test(email)) { form.email.classList.add('invalid'); showValidation('email'); return; }

        btn.disabled = true;
        try {
          const res = await fetch(form.dataset.api, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, platform, lang: document.documentElement.lang || 'es' }),
          });
          if (!res.ok) throw new Error('Request failed');
          showStep(successStep);
        } catch (err) {
          errorEl.style.display = 'block';
          btn.disabled = false;
        }
      });
    }

    setupForm('testerForm', 'testerValidation', 'successManual');
    setupForm('testerFormIos', 'testerValidationIos', 'successIos');

    // ── Stepper logic for Android success flow ──
    (function initStepper() {
      var items = overlay.querySelectorAll('.tm-stepper-item');
      if (!items.length) return;
      var current = 0;

      function update() {
        items.forEach(function(item, i) {
          item.classList.remove('tm-stepper-active', 'tm-stepper-done');
          var num = item.querySelector('.tm-stepper-num');
          if (i < current) {
            item.classList.add('tm-stepper-done');
            num.innerHTML = '<i class="ph ph-check"></i>';
          } else if (i === current) {
            item.classList.add('tm-stepper-active');
            num.textContent = String(i + 1);
          } else {
            num.textContent = String(i + 1);
          }
        });
      }

      items.forEach(function(item, i) {
        var btn = item.querySelector('.tm-stepper-confirm');
        if (btn) {
          btn.addEventListener('click', function() {
            if (i === current) { current++; update(); }
          });
        }
      });

      update();
    })();

    // Update placeholders on lang change
    const langObserver = new MutationObserver(() => {
      const lang = document.documentElement.lang || 'es';
      overlay.querySelectorAll('[data-placeholder-es]').forEach(input => {
        input.placeholder = input.getAttribute('data-placeholder-' + lang) || input.placeholder;
      });
    });
    langObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['lang'] });
  })();
</script>
