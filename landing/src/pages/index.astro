  <!-- ═══════════════════ SCRIPTS ═══════════════════ -->
  <script>
    // ── Scroll Reveal ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ── Gallery Coverflow ──
    (() => {
      const stage = document.getElementById('galleryStage');
      const track = document.getElementById('galleryTrack');
      const dotsContainer = document.getElementById('galleryDots');
      if (!stage || !track || !dotsContainer) return;

      const phones = Array.from(track.querySelectorAll('.gallery-phone'));
      if (!phones.length) return;

      const total = phones.length;
      let active = 0;

      // Build dot indicators
      phones.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'gallery-dot';
        dot.setAttribute('role', 'tab');
        dot.setAttribute('aria-label', `Slide ${i + 1}`);
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      });
      const dots = Array.from(dotsContainer.children);

      const classFor = (i) => {
        let d = i - active;
        if (d > total / 2) d -= total;
        if (d < -total / 2) d += total;
        if (d === 0) return 'is-active';
        if (d === -1) return 'is-near-prev';
        if (d === 1) return 'is-near-next';
        if (d === -2) return 'is-far-prev';
        if (d === 2) return 'is-far-next';
        return '';
      };

      const update = () => {
        phones.forEach((phone, i) => {
          phone.classList.remove('is-active', 'is-near-prev', 'is-near-next', 'is-far-prev', 'is-far-next');
          const cls = classFor(i);
          if (cls) phone.classList.add(cls);

          // Pause/play the video to save CPU when off-center
          const video = phone.querySelector('video');
          if (video) {
            if (i === active) {
              const p = video.play();
              if (p && typeof p.catch === 'function') p.catch(() => {});
            } else {
              video.pause();
            }
          }
        });
        dots.forEach((d, i) => d.classList.toggle('is-active', i === active));
      };

      const goTo = (i) => {
        active = ((i % total) + total) % total;
        update();
      };
      const next = () => goTo(active + 1);
      const prev = () => goTo(active - 1);

      // Gallery lightbox
      const overlay = document.getElementById('galleryOverlay');
      const lbImg = document.getElementById('galleryLightbox');
      const lbVideo = document.getElementById('galleryLightboxVideo');
      const closeLightbox = () => {
        overlay.classList.remove('open');
        lbImg.style.display = 'none';
        lbVideo.style.display = 'none';
        lbVideo.pause();
        startAutoplay();
      };
      overlay.addEventListener('click', closeLightbox);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay.classList.contains('open')) closeLightbox();
      });

      // Click-to-focus or open lightbox on active phone
      phones.forEach((phone, i) => {
        phone.addEventListener('click', (e) => {
          if (i !== active) {
            e.preventDefault();
            goTo(i);
            return;
          }
          stopAutoplay();
          const img = phone.querySelector('img');
          const video = phone.querySelector('video');
          if (video) {
            lbVideo.src = video.src;
            lbVideo.style.display = 'block';
            const p = lbVideo.play();
            if (p && typeof p.catch === 'function') p.catch(() => {});
          } else if (img) {
            lbImg.src = img.src;
            lbImg.alt = img.alt;
            lbImg.style.display = 'block';
          }
          overlay.classList.add('open');
        });
      });

      // Keyboard: arrows when stage is focused / hovered
      stage.setAttribute('tabindex', '0');
      stage.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); next(); }
      });

      // Touch swipe (snappy: low threshold, low velocity gate)
      let touchStartX = 0;
      let touchStartY = 0;
      let touchActive = false;
      stage.addEventListener('touchstart', (e) => {
        if (!e.touches[0]) return;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchActive = true;
        stopAutoplay();
      }, { passive: true });
      stage.addEventListener('touchend', (e) => {
        if (!touchActive || !e.changedTouches[0]) return;
        touchActive = false;
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) < 30 || Math.abs(dx) < Math.abs(dy)) {
          startAutoplay();
          return;
        }
        if (dx < 0) next(); else prev();
        startAutoplay();
      }, { passive: true });

      // Autoplay — pause on hover, resume on leave
      let autoplayId = null;
      const AUTOPLAY_MS = 4500;
      const startAutoplay = () => {
        stopAutoplay();
        autoplayId = window.setInterval(next, AUTOPLAY_MS);
      };
      const stopAutoplay = () => {
        if (autoplayId) { clearInterval(autoplayId); autoplayId = null; }
      };
      stage.addEventListener('mouseenter', stopAutoplay);
      stage.addEventListener('mouseleave', startAutoplay);
      // Pause when tab is hidden (saves cycles, avoids surprise jumps on return)
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stopAutoplay(); else startAutoplay();
      });

      // Initial paint — first item is the protagonist
      update();
      startAutoplay();
    })();

    // ── Bilingual Toggle ──
    function setLang(lang) {
      document.querySelectorAll('.lang-toggle button').forEach(b => b.classList.remove('active'));
      const activeBtn = document.querySelector(`.lang-toggle button[data-lang="${lang}"]`);
      if (activeBtn) activeBtn.classList.add('active');
      document.documentElement.lang = lang;
      document.querySelectorAll('[data-es][data-en]').forEach(el => {
        const text = el.getAttribute(`data-${lang}`);
        if (text) el.textContent = text;
      });
    }

    // Auto-detect language
    const browserLang = (navigator.language || '').slice(0, 2);
    if (browserLang === 'en') setLang('en');

    document.querySelectorAll('.lang-toggle button').forEach(btn => {
      btn.addEventListener('click', () => setLang(btn.dataset.lang));
    });
    // ── Live locations count (lightweight endpoint, not the full locations API) ──
    (async () => {
      try {
        const res = await fetch('https://games.sabino.cl/zoominchile/api/stats');
        if (!res.ok) return;
        const stats = await res.json();
        const count = stats.activeLocations || 0;
        if (!count) return;
        const lang = document.documentElement.lang || 'es';
        const chip = document.getElementById('locationsChip');
        const text = document.getElementById('locationsText');
        const esText = `${count} lugares`;
        const enText = `${count} locations`;
        text.setAttribute('data-es', esText);
        text.setAttribute('data-en', enText);
        text.textContent = lang === 'en' ? enText : esText;
        chip.classList.add('stat-chip-live');
        const dot = document.createElement('span');
        dot.className = 'live-dot';
        dot.setAttribute('aria-label', 'Live');
        chip.insertBefore(dot, chip.firstChild);
        // Update hero chat bubble with real count
        const b1 = document.getElementById('heroBubble1');
        if (b1) {
          const sp = b1.querySelector('span');
          sp.setAttribute('data-es', `Solo ${count} lugares, Gato?`);
          sp.setAttribute('data-en', `Only ${count} locations, Gato?`);
          sp.textContent = lang === 'en' ? `Only ${count} locations, Gato?` : `Solo ${count} lugares, Gato?`;
        }
      } catch (_) {}
    })();

    // ── Tester Spots ──
    (async () => {
      try {
        const res = await fetch('https://games.sabino.cl/zoominchile/api/tester-spots');
        if (!res.ok) return;
        const { spots, registered } = await res.json();
        const remaining = Math.max(0, spots - registered);
        if (remaining <= 0) return;
        const lang = document.documentElement.lang || 'es';
        const el = document.getElementById('spotsText');
        const container = document.getElementById('ctaSpots');
        el.setAttribute('data-es', `Solo ${remaining} cupos disponibles`);
        el.setAttribute('data-en', `Only ${remaining} spots left`);
        el.textContent = lang === 'en' ? `Only ${remaining} spots left` : `Solo ${remaining} cupos disponibles`;
        container.style.display = '';
      } catch (_) {}
    })();

    // ── Hall of Fame ──
    (async () => {
      const loading = document.getElementById('hofLoading');
      const list = document.getElementById('hofList');
      const empty = document.getElementById('hofEmpty');
      const footer = document.getElementById('hofFooter');
      const modal = document.getElementById('hofModal');
      const modalClose = document.getElementById('hofModalClose');
      const modalLoading = document.getElementById('hofModalLoading');
      const modalList = document.getElementById('hofModalList');
      const viewAllBtn = document.getElementById('hofViewAll');

      const showEmpty = () => {
        loading.style.display = 'none';
        list.style.display = 'none';
        footer.style.display = 'none';
        empty.style.display = 'flex';
      };

      const medalColors = { 1: '#C9A961', 2: '#BFC7CF', 3: '#CD7F32' };
      const fmtPts = (n) => n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K' : String(n);

      const rowHtml = (e, i) => {
        const rank = e.rank ?? i + 1;
        const pts = e.totalPoints ?? e.points ?? 0;
        const initials = (e.initials || '---').toString().toUpperCase();
        const rankEl = rank <= 3
          ? `<i class="ph-fill ph-medal hof-medal" style="color:${medalColors[rank]}"></i>`
          : `<span class="hof-rank">#${rank}</span>`;
        const top1 = rank === 1 ? ' is-top1' : '';
        return `
          <div class="hof-row${top1}">
            <div class="hof-rank-col">${rankEl}</div>
            <div class="hof-initials">${initials}</div>
            <div class="hof-points">${fmtPts(pts)}<span class="hof-points-unit">pts</span></div>
          </div>
        `;
      };

      const cardHtml = (e, i) => {
        const rank = e.rank ?? i + 1;
        const pts = e.totalPoints ?? e.points ?? 0;
        const initials = (e.initials || '---').toString().toUpperCase();
        const medalEl = rank <= 3
          ? `<i class="ph-fill ph-medal hof-podium-medal" style="color:${medalColors[rank]}"></i>`
          : `<span class="hof-podium-rank-pill">#${rank}</span>`;
        const rankNum = rank <= 3
          ? `<div class="hof-podium-rank">${rank}</div>` : '';
        const classes = ['hof-podium-card', `is-rank-${rank}`];
        if (rank === 4) classes.push('is-fourth');
        return `
          <div class="${classes.join(' ')}">
            ${rankNum}
            ${medalEl}
            <div class="hof-podium-initials">${initials}</div>
            <div class="hof-podium-points">${fmtPts(pts)}<span class="hof-podium-points-unit">pts</span></div>
          </div>
        `;
      };

      // Modal open/close wiring (set up regardless of fetch outcome)
      const openModal = () => modal.classList.add('open');
      const closeModal = () => modal.classList.remove('open');
      modalClose.addEventListener('click', closeModal);
      modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
      });
      viewAllBtn.addEventListener('click', openModal);

      try {
        const res = await fetch('https://games.sabino.cl/zoominchile/api/leaderboard?limit=10');
        if (!res.ok) { showEmpty(); return; }
        const data = await res.json();
        const entries = Array.isArray(data) ? data : (data.entries || []);
        if (!entries.length) { showEmpty(); return; }

        // Inline: top 4 (podium pricing-pack cards)
        list.innerHTML = entries.slice(0, 4).map(cardHtml).join('');
        loading.style.display = 'none';
        list.style.display = 'grid';

        // Footer "View all" only when there are more than 4 entries
        if (entries.length > 4) {
          footer.style.display = 'flex';
        }

        // Modal: full top 10
        modalList.innerHTML = entries.map(rowHtml).join('');
        modalLoading.style.display = 'none';
        modalList.style.display = 'flex';
      } catch (_) {
        showEmpty();
      }
    })();
  </script>
</body>
</html>
