  <!-- ═══════════════════ SCRIPTS ═══════════════════ -->
  <script>
    // ── Scroll Reveal ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ── Bilingual Toggle ──
    function setLang(lang) {
      document.querySelectorAll('.lang-toggle button').forEach(b => b.classList.remove('active'));
      const activeBtn = document.querySelector(`.lang-toggle button[data-lang="${lang}"]`);
      if (activeBtn) activeBtn.classList.add('active');
      document.documentElement.lang = lang;
      document.querySelectorAll('[data-es][data-en]').forEach(el => {
        const text = el.getAttribute(`data-${lang}`);
        if (text) el.textContent = text;
      });
    }

    // Auto-detect language
    const browserLang = (navigator.language || '').slice(0, 2);
    if (browserLang === 'en') setLang('en');

    document.querySelectorAll('.lang-toggle button').forEach(btn => {
      btn.addEventListener('click', () => setLang(btn.dataset.lang));
    });
    // ── Tester Spots ──
    (async () => {
      try {
        const res = await fetch('https://games.sabino.cl/zoominchile/api/tester-spots');
        if (!res.ok) return;
        const { spots, registered } = await res.json();
        const remaining = Math.max(0, spots - registered);
        if (remaining <= 0) return;
        const lang = document.documentElement.lang || 'es';
        const el = document.getElementById('spotsText');
        const container = document.getElementById('ctaSpots');
        el.setAttribute('data-es', `Solo ${remaining} cupos disponibles`);
        el.setAttribute('data-en', `Only ${remaining} spots left`);
        el.textContent = lang === 'en' ? `Only ${remaining} spots left` : `Solo ${remaining} cupos disponibles`;
        container.style.display = '';
      } catch (_) {}
    })();
  </script>
