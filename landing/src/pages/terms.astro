---
const baseUrl = import.meta.env.BASE_URL;
---

<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href={`${baseUrl}icon.png`} />
  <title>Terms of Service — Zoom-In Chile</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700&family=Plus+Jakarta+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #0F1D24;
      --bg-card: #162A35;
      --accent: #E25822;
      --text: #EAEAEA;
      --text-dim: #8A9BA5;
      --font-display: 'Space Grotesk', sans-serif;
      --font-body: 'Plus Jakarta Sans', sans-serif;
    }
    body {
      font-family: var(--font-body);
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
    }
    .container {
      max-width: 720px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }
    nav {
      padding: 1rem 2rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    nav a {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      color: var(--text-dim);
      font-size: 0.9rem;
      font-weight: 500;
      transition: color 0.2s;
    }
    nav a:hover { color: var(--text); }
    nav img { height: 28px; border-radius: 6px; }
    h1 {
      font-family: var(--font-display);
      font-size: 2.2rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }
    .updated {
      color: var(--text-dim);
      font-size: 0.85rem;
      margin-bottom: 2.5rem;
    }
    h2 {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 700;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      color: var(--accent);
    }
    p, li {
      color: var(--text-dim);
      margin-bottom: 0.75rem;
    }
    ul { padding-left: 1.5rem; }
    a { color: var(--accent); }
  </style>
</head>
<body>
  <nav>
    <a href={baseUrl}>
      <img src={`${baseUrl}icon.png`} alt="" />
      <span>&larr; Zoom-In Chile</span>
    </a>
  </nav>
  <div class="container">
    <h1>Terms of Service</h1>
    <p class="updated">Last updated: April 8, 2026</p>

    <h2>Acceptance</h2>
    <p>By downloading or using Zoom-In Chile ("the App"), you agree to these Terms of Service. If you do not agree, do not use the App.</p>

    <h2>Description</h2>
    <p>Zoom-In Chile is a free puzzle game featuring photographs of real locations in Chile. The App is provided by Depointless.</p>

    <h2>Use of the App</h2>
    <ul>
      <li>The App is free to download and play.</li>
      <li>The App contains advertisements served by Google AdMob.</li>
      <li>You may not use the App for any unlawful purpose.</li>
      <li>You may not attempt to manipulate leaderboard scores or exploit the App.</li>
    </ul>

    <h2>Intellectual Property</h2>
    <p>All photographs in the App are original work by Sabino & Ximena. Sound effects by Vilkas Sound (CC BY 4.0). All other content is owned by Depointless. You may not reproduce, distribute, or create derivative works without permission.</p>

    <h2>Disclaimer</h2>
    <p>The App is provided "as is" without warranties of any kind. Depointless is not liable for any damages arising from the use of the App.</p>

    <h2>Changes</h2>
    <p>We reserve the right to modify these Terms at any time. Continued use of the App constitutes acceptance of the updated Terms.</p>

    <h2>Contact</h2>
    <p>Questions? Contact us at <a href="mailto:contact@depointless.cl">contact@depointless.cl</a>.</p>
  </div>
</body>
</html>
